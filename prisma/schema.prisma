// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



enum Role {
  ADMIN
  USER
}

enum Subscription {
  STARTER
  STANDARD
  PREMIUM
}

enum Status {
  IMPORTANT
  REGULAR
}

enum EventStatus {
  PLANNED
  CANCELLED
  DONE
}

enum EventPriority {
  LOW
  MEDIUM
  HIGH
}

enum NotificationType {
  INFO
  ALERT
  REMINDER
}

enum PaymentStatus {
  PENDING     
  PAID        
  FAILED     
  CANCELED   
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BlockType {
  PARAGRAPH
  HEADING
  IMAGE
  QUOTE
  CODE
  LIST
}

model User {
  id          String       @id @default(uuid())
  email       String       @unique
  password    String
  fullName    String
  role        Role         @default(USER)

  subscription Subscription @default(STARTER)
  isActiveSubscription Boolean @default(false)
  verifyPayment Boolean @default(false)
  stripeCustomerId String?
  stripeSubscriptionId String?
  payments Payment[]

  isActive    Boolean @default(false)
  lastLogin   DateTime?

  address     String?
  zipCode     String?
  city        String?
  country     String?

  profile     Profile?
  ships       Ship[]
  addressBook AddressBook[]
  events Event[]
  notifications Notification[]
  posts Post[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Otp {
  id String   @id @default(uuid())
  email String @unique
  otp String
  expiresAt DateTime
}

model Profile {
  id       Int  @id @default(autoincrement())
  fullName String?
  avatar   String?
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String  @unique
  createdAt   DateTime     @default(now())
  updatedAt DateTime @updatedAt
}


model Ship {
  id              String   @id @default(uuid())
  shipName        String
  slug            String @unique @default("default-slug")

  shipType        ShipType? @relation(fields: [typeId], references: [id], onDelete: Cascade)
  typeId          String?

  imo             Int  @unique
  refitYear       Int?
  buildYear       Int?
  price           Float
  location        String?
  latitude        Float?
  longitude       Float?
  mainEngine      String?
  lengthOverall   Float?
  beam            Float?
  length          Float?
  depth           Float?
  draft           Float?
  tonnage         Float?
  cargoCapacity   String?
  buildCountry    String?
  remarks         String?
  description     String?

  mainImage       String?
  mainImageAlt    String?
  mainImagePublicId String?

  images          ShipImages[]

  clicks          Int      @default(0)

  user            User     @relation(fields: [userId], references: [id],onDelete: Cascade)
  userId          String

  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
}

model ShipImages {
  id      String    @id @default(uuid())
  alt     String?
  url     String
  publicId String?

  shipId  String
  ship    Ship   @relation(fields: [shipId], references: [id],onDelete: Cascade)

  createdAt DateTime @default(now())
}



model ShipType {
  id          String @id @default(uuid())
  name        String @unique
  description String?
  ships       Ship[]
  createdAt   DateTime @default(now())
}

model AddressBook {
  id              String   @id @default(uuid())
  fullName        String
  email           String
  phone_number    String?
  mobile_number   String?
  country         String?
  address_2       String?
  web_link        String?
  linkedin_link   String?
  facebook_link   String?
  instagram_link  String?
  tiktok_link     String?
  priority        Status   @default(REGULAR)
  company         String?
  address         String?
  note            String?

  user            User     @relation(fields: [userId], references: [id])
  userId          String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Event {
  id String @id @default(uuid())
  title String
  description String?
  start       DateTime
  end         DateTime
  location    String?
  reminder    Int?       
  status      EventStatus? @default(PLANNED)
  priority    EventPriority? @default(MEDIUM)
  tags        String[] 

  user User @relation(fields: [userId], references: [id])
  userId String
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Notification {
  id       Int  @id @default(autoincrement())
  message  String
  type NotificationType @default(INFO)
  isRead    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  userId String
}

model Payment {
  id String @id @default(uuid())

  user User @relation(fields: [userId], references: [id])
  userId String

  status          PaymentStatus  @default(PENDING)
  amount Float
  currency String @default("EUR")
  stripePaymentId String
  createdAt DateTime @default(now())
}

model Post {
  id String @id @default(uuid())

  author User @relation(fields: [authorId], references: [id])
  authorId String

  title String
  subTitle String?
  slug String @unique @default("post-slug")
  status PostStatus @default(DRAFT)

  blocks PostBlock[]

  category PostCategory? @relation(fields: [categoryId], references: [id])
  categoryId Int?

  tags String[]

  bannerImage String?
  bannerPublicId String?
  bannerImageAlt String?
  gallery PostGallery[]

  publishedAt DateTime?

  metaTitle String?
  metaDescription String?
  metaKeywords String?

  ogImage String?
  canonicalUrl String?

  readingTime Int?
  views Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([status])
}

model PostBlock {
  id      String    @id @default(uuid())

  postId  String
  post    Post   @relation(fields: [postId], references: [id],onDelete: Cascade)

  text      String?   @db.Text
  imageUrl  String?
  imageAlt  String?

  order     Int
  createdAt DateTime @default(now())

  @@index([postId])
}

model PostGallery {
  id      String    @id @default(uuid())
  alt     String?
  url     String
  publicId String?

  postId  String
  post    Post   @relation(fields: [postId], references: [id],onDelete: Cascade)

  createdAt DateTime @default(now())
}

model PostCategory {
  id Int  @id @default(autoincrement())
  title String

  post Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}